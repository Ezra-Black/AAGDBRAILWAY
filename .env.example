# Local development — copy to .env and fill in values.
# On Railway these are set automatically / in the dashboard.

# PostgreSQL connection string
# Local:  postgresql://user:password@localhost:5432/aagdb
# Railway: use DATABASE_URL from the Postgres service
# Prefer the private URL (DATABASE_URL / DATABASE_PRIVATE_URL) so only the backend talks to the DB
DATABASE_URL=postgresql://postgres:password@localhost:5432/aagdb

# Server
PORT=3000
NODE_ENV=development

# Optional: comma-separated origins for CORS
# CORS_ORIGIN=http://localhost:3000,https://your-app.up.railway.app

# Rate limits (per IP)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=120
SUBMIT_RATE_WINDOW_MS=900000
SUBMIT_RATE_MAX=8
LOGIN_RATE_WINDOW_MS=900000
LOGIN_RATE_MAX=8
READ_RATE_MAX=60

# Same email + angel name cannot resubmit within this many hours
SUBMIT_COOLDOWN_HOURS=24

# Optional: protect /pending /entries /lookup /entry/* with header x-api-key
# AUTOMATION_API_KEY=generate-a-long-random-string

# ── Facebook quick sign-in (optional) ─────────────────────────────
# Create an app at https://developers.facebook.com, enable Facebook Login,
# and add your site URL to the allowed domains. When both are set, visitors
# with an active Facebook session get a one-tap "Continue with Facebook"
# prompt that asks them to share their email (stored securely, business
# purposes only). Leave unset to disable the feature entirely.
# FB_APP_ID=your-facebook-app-id
# FB_APP_SECRET=your-facebook-app-secret

# ── Contact-form email forwarding (optional) ──────────────────────
# Contact messages are always stored in Postgres. When SMTP is configured
# they are ALSO forwarded to CONTACT_EMAIL_TO (defaults to the studio
# ProtonMail inbox). ProtonMail itself doesn't accept direct SMTP logins on
# free plans — use Proton Mail Bridge, a Proton SMTP token (paid plans), or
# any transactional relay (Resend, Mailgun, SendGrid, ...) that delivers to
# the inbox below.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=postmaster@example.com
# SMTP_PASS=your-smtp-password
# SMTP_FROM="Audrey's Angel Graphics <no-reply@example.com>"
# CONTACT_EMAIL_TO=aaggraphics@protonmail.com
