{
  "name": "aagdb-railway",
  "version": "1.0.0",
  "description": "Angel Name form + PostgreSQL on Railway — automation-ready for photo generation",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "engines": {
