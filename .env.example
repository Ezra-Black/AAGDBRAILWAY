# Local development — copy to .env and fill in values.
# On Railway these are set automatically / in the dashboard.

# PostgreSQL connection string
# Local:  postgresql://user:password@localhost:5432/aagdb
# Railway: use DATABASE_URL from the Postgres service
# Prefer the private URL (DATABASE_URL / DATABASE_PRIVATE_URL) so only the backend talks to the DB
DATABASE_URL=postgresql://postgres:password@localhost:5432/aagdb

# Server
PORT=3000
NODE_ENV=development

# Optional: comma-separated origins for CORS
# CORS_ORIGIN=http://localhost:3000,https://your-app.up.railway.app

# Rate limits (per IP)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=120
SUBMIT_RATE_WINDOW_MS=900000
SUBMIT_RATE_MAX=8
LOGIN_RATE_WINDOW_MS=900000
LOGIN_RATE_MAX=8
READ_RATE_MAX=60

# Same email + angel name cannot resubmit within this many hours
SUBMIT_COOLDOWN_HOURS=24

# ── User accounts (login / profile portal) ────────────────────────
# Auth is session-based: opaque random tokens in httpOnly Secure cookies,
# only SHA-256 hashes stored in Postgres — no JWT secret is needed.
#
# Public URL of the site, used in password-reset emails. On Railway set it
# to your public domain (e.g. https://your-app.up.railway.app). When unset,
# links are built from the request's Host header.
# PUBLIC_BASE_URL=https://your-app.up.railway.app
#
# Where profile photos are stored. On Railway, attach a Volume to the
# service and point this at its mount path so photos survive redeploys
# (e.g. /data/uploads). Defaults to ./uploads (ephemeral without a volume).
# UPLOAD_DIR=/data/uploads
#
# Rate limits for the auth endpoints (per IP)
# USER_AUTH_RATE_WINDOW_MS=900000
# USER_AUTH_RATE_MAX=10
# PASSWORD_RESET_RATE_MAX=5
# PROFILE_RATE_MAX=30
#
# Password-reset emails use the SMTP settings below (SMTP_HOST/USER/PASS).
# Without SMTP, forgot-password still responds safely but no email goes out.

# ── Analytics (privacy-friendly, first-party) ─────────────────────
# Optional: random string used to hash anonymous visitor ids before storage.
# ANALYTICS_SALT=generate-a-long-random-string
# Page-view beacons allowed per IP per minute
# TRACK_RATE_MAX=30

# Optional: protect /pending /entries /lookup /entry/* with header x-api-key
# AUTOMATION_API_KEY=generate-a-long-random-string

# ── Archive shop (Stripe) ─────────────────────────────────────────
# The $5 AAG Archive Graphic purchase. Get keys from
# https://dashboard.stripe.com/apikeys — use sk_test/pk_test while testing,
# then swap to live keys (sk_live/pk_live) when ready to take real payments.
# NEVER commit the secret key to git.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# Optional: verify payments via webhook too (Stripe dashboard → Webhooks →
# endpoint https://YOUR_DOMAIN/stripe/webhook, events payment_intent.*)
# STRIPE_WEBHOOK_SECRET=whsec_...
# Price in cents (default 500 = $5)
# SHOP_PRICE_CENTS=500

# ── Facebook quick sign-in (optional) ─────────────────────────────
# Create an app at https://developers.facebook.com, enable Facebook Login,
# and add your site URL to the allowed domains. When both are set, visitors
# with an active Facebook session get a one-tap "Continue with Facebook"
# prompt that asks them to share their email (stored securely, business
# purposes only). Leave unset to disable the feature entirely.
# FB_APP_ID=your-facebook-app-id
# FB_APP_SECRET=your-facebook-app-secret

# ── Contact-form email forwarding (optional) ──────────────────────
# Contact messages are always stored in Postgres. When SMTP is configured
# they are ALSO forwarded to CONTACT_EMAIL_TO (defaults to the studio
# ProtonMail inbox). ProtonMail itself doesn't accept direct SMTP logins on
# free plans — use Proton Mail Bridge, a Proton SMTP token (paid plans), or
# any transactional relay (Resend, Mailgun, SendGrid, ...) that delivers to
# the inbox below.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=postmaster@example.com
# SMTP_PASS=your-smtp-password
# SMTP_FROM="Audrey's Angel Graphics <no-reply@example.com>"
# CONTACT_EMAIL_TO=aaggraphics@protonmail.com
